@model IList<LMS.DTOs.CourseDto>
@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Courses</h2>
    @if (User.IsInRole("Instructor") || User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">Create Course</a>
    }
</div>

@if (!Model.Any())
{
    <p class="text-muted">No courses available yet.</p>
}
else
{
    <div class="row g-4">
        @foreach (var course in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@course.Title</h5>
                        <p class="card-text text-muted">@(course.Description.Length > 100 ? course.Description[..100] + "..." : course.Description)</p>
                        <p class="card-text"><small>Instructor: @course.InstructorName</small></p>
                        <p class="card-text"><small>@course.EnrolledCount student(s) enrolled</small></p>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
