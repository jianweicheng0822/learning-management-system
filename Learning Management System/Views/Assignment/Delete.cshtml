@model LMS.DTOs.AssignmentDto
@{
    ViewData["Title"] = "Delete Assignment";
}

<h2>Delete Assignment</h2>
<div class="alert alert-danger">
    <p>Are you sure you want to delete <strong>@Model.Title</strong>?</p>
    <p>This will also remove all submissions and grades for this assignment.</p>
</div>

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>
    <dt class="col-sm-3">Course</dt>
    <dd class="col-sm-9">@Model.CourseName</dd>
    <dt class="col-sm-3">Due Date</dt>
    <dd class="col-sm-9">@Model.DueDate.ToString("MMM dd, yyyy HH:mm")</dd>
    <dt class="col-sm-3">Submissions</dt>
    <dd class="col-sm-9">@Model.SubmissionCount</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
</form>
