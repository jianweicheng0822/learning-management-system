@model ProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<h2>Edit Profile</h2>

<div class="row">
    <div class="col-md-5">
        <div asp-validation-summary="All" class="text-danger"></div>
        <form asp-action="EditProfile" method="post">
            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input class="form-control" value="@Model.Email" disabled />
            </div>
            <div class="mb-3">
                <label class="form-label">Role(s)</label>
                <input class="form-control" value="@string.Join(", ", Model.Roles)" disabled />
            </div>
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Profile" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
